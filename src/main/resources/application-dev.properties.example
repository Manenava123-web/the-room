# ═══════════════════════════════════════════
# PERFIL: dev  (local)
# Copia este archivo como application-dev.properties
# y rellena tus valores locales.
# ═══════════════════════════════════════════

server.port=8080

# MySQL
spring.datasource.url=jdbc:mysql://localhost:3306/theroom_db?useSSL=false&serverTimezone=America/Mexico_City&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_LOCAL

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# JWT
app.jwt.secret=cambia-esto-por-una-clave-larga-aleatoria

# CORS
app.cors.allowed-origins=*,https://*.ngrok-free.app,https://*.ngrok.io

# Uploads
app.upload.dir=uploads

# OpenPay — sandbox
openpay.merchant-id=TU_MERCHANT_ID_SANDBOX
openpay.private-key=TU_PRIVATE_KEY_SANDBOX
openpay.public-key=TU_PUBLIC_KEY_SANDBOX
openpay.sandbox=true

# Frontend URL
app.frontend-url=http://localhost:8080

# Email (Gmail app password)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=TU_CORREO@gmail.com
spring.mail.password=TU_APP_PASSWORD_GMAIL
